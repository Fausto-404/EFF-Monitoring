# ==========================================
# EFF-Monitoring v2.1.4  环境变量配置模板
# ==========================================
# 使用方法: cp .env.example .env  然后修改敏感值
# Docker 部署需要 .env 文件存在，不能跳过。
#
# 注意: 本文件仅包含后端/数据库相关变量。
# 前端 VITE_API_BASE_URL 是构建时变量，不应出现在此文件中。
# 本地开发时在 frontend/.env.local 中设置即可。
# ==========================================

# --- 数据库 ---
# PostgreSQL 超级用户密码（首次初始化后，修改此值需重建数据卷）
POSTGRES_PASSWORD=eff_password
DATABASE_URL=postgresql+psycopg://eff:eff_password@eff-postgres:5432/eff_monitoring
REDIS_URL=redis://eff-redis:6379/0

# --- 安全密钥（生产环境务必修改！）---
# JWT_SECRET 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=replace-with-a-long-random-secret
INITIAL_ADMIN_PASSWORD=admin123

# --- 可选配置 ---
INITIAL_ADMIN_USERNAME=admin
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
APP_TIMEZONE=Asia/Shanghai

# --- 演示数据 ---
# 演示用户密码，注释掉则使用默认值 demo123456
# 生产环境建议部署后停用或删除演示账号
ENABLE_DEMO_DATA=false
# DEMO_USER_PASSWORD=demo123456
